---
// src/components/BranchesGrid.astro
export interface Branch {
  city: string;
  title?: string;
  address?: string;
  phone?: string;
  coords?: { lat: number; lng: number };
}

const { branches = [] } = Astro.props as { branches: Branch[] };

// import all images from src/assets/sucursales (eager, as url)
const images = import.meta.glob('../assets/sucursales/*.{webp,png,jpg,jpeg,svg}', { eager: true, as: 'url' }) as Record<string, string>;

/** Normaliza texto: quita acentos, caracteres extra y trim */
function normalizeName(s = '') {
  return s
    .toString()
    .trim()
    .normalize('NFD')                    // separa diacríticos
    .replace(/[\u0300-\u036f]/g, '')     // quita diacríticos
    .replace(/[^a-zA-Z0-9\s-_]/g, '')    // deja solo alfanum, espacios, - y _
    .replace(/\s+/g, ' ')                // normaliza espacios
    .toUpperCase();
}

/** Crea mapa filename(normalizado) => url */
const imageMap = Object.keys(images).reduce<Record<string, string>>((acc, path) => {
  const file = path.split('/').pop() || '';
  const name = file.split('.').slice(0, -1).join('.') || file; // nombre sin extensión
  const key = normalizeName(name);
  acc[key] = images[path];
  return acc;
}, {});

/** Busca la mejor coincidencia para una ciudad */
function findImageForCity(city?: string) {
  if (!city) return null;
  const base = normalizeName(city);
  const variants = [
    base,
    base.replace(/\s+/g, ''),   // sin espacios
    base.replace(/\s+/g, '_'),  // underscore
    base.replace(/\s+/g, '-'),  // guion
  ];
  for (const v of variants) {
    if (imageMap[v]) return imageMap[v];
  }
  return null;
}

function cleanPhone(t?: string) {
  if (!t) return '';
  return t.replace(/[^\d+]/g, '');
}

function initialsFromCity(city = '') {
  return city
    .split(/\s+/)
    .map((w) => w[0] ?? '')
    .filter(Boolean)
    .slice(0, 2)
    .join('')
    .toUpperCase();
}
---
<section class="pt-12 lg:pt-24" id="sucursales">
  <div class="max-w-7xl mx-auto px-2">
    <h2 class="text-2xl md:text-4xl font-black tracking-tight text-center text-zinc-950">
      Nuestras sucursales
    </h2>
    <p class="text-lg md:text-xl text-zinc-800 max-w-[720px] mx-auto my-2">
      En <strong>AlfaCredit,S.A.</strong> contamos con una red de sucursales ubicadas estratégicamente en distintos departamentos del país para brindarte atención personalizada, ágil y cercana.
    </p>

    <div
      class="
        grid 
        grid-cols-1
        sm:grid-cols-2
        lg:grid-cols-3
        gap-6
        items-start
      "
    >
      {branches.map((b) => {
        const img = findImageForCity(b.city);
        return (
          <article class="w-full sm:h-full max-w-[720px] bg-zinc-100 px-2 md:px-4 pb-4 md:pb-6 pt-2 md:pt-4 rounded-2xl border-2 border-white hover:border-zinc-200 hover:bg-zinc-50 transition">
            {/* Imagen o placeholder */}
            {img ? (
              <img src={img} alt={`${b.city} - sucursal`} class="w-full h-40 md:h-70 object-cover rounded-lg mb-4" />
            ) : (
              <div class="w-full h-40 md:h-70 rounded-lg bg-zinc-200 mb-4 flex items-center justify-center text-zinc-600 font-bold text-2xl">
                {initialsFromCity(b.city)}
              </div>
            )}
            
              <div class="flex justify-between">
                
            <h3 class="text-xl md:text-2xl font-black text-zinc-950 uppercase">{b.city}</h3>
            {b.coords && (
              <button
                class="font-bold text-sm cursor-pointer hover:opacity-80 transition duration-150 hover:underline"
                data-branch-map={b.city}
                data-lat={b.coords.lat}
                data-lng={b.coords.lng}
              >
                🗺️​VER EN MAPA
              </button>
            )}
              </div>

            {b.address && <p class="text-lg md:text-xl text-zinc-800 mt-2 leading-relaxed">{b.address}</p>}

            {b.phone && (
              <p class="mt-3">
                <a class="font-semibold" href={`tel:${cleanPhone(b.phone)}`}>📞{b.phone}</a>
              </p>
            )}
          </article>
        );
      })}
    </div>

    <div
      id="branch-map-modal"
      class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4"
      role="dialog"
      aria-modal="true"
      aria-labelledby="branch-map-title"
    >
      <div class="relative w-full max-w-5xl rounded-3xl bg-white shadow-2xl overflow-hidden">
        <button
          id="branch-map-close"
          type="button"
          class="absolute right-4 top-4 rounded-full bg-zinc-900/90 text-white w-10 h-10 flex items-center justify-center hover:bg-zinc-900"
          aria-label="Cerrar mapa"
        >
          ✕
        </button>

        <div class="aspect-video bg-zinc-200">
          <iframe
            id="branch-map-iframe"
            src=""
            class="w-full h-full"
            frameborder="0"
            allowfullscreen=""
            loading="lazy"
          ></iframe>
        </div>

        <div class="p-6">
          <h3 id="branch-map-title" class="text-xl font-bold text-zinc-950"></h3>
          <p id="branch-map-coords" class="mt-1 text-sm text-zinc-600"></p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const modal = document.getElementById('branch-map-modal') as HTMLElement | null;
  const iframe = document.getElementById('branch-map-iframe') as HTMLIFrameElement | null;
  const title = document.getElementById('branch-map-title') as HTMLElement | null;
  const coordsText = document.getElementById('branch-map-coords') as HTMLElement | null;
  const closeBtn = document.getElementById('branch-map-close') as HTMLElement | null;

  function openMapModal(city: string, lat: string, lng: string) {
    if (!modal || !iframe || !title || !coordsText) return;
    const src = `https://www.google.com/maps?q=${lat},${lng}&z=15&output=embed`;
    title.textContent = `Sucursal ${city}`;
    coordsText.textContent = `Coordenadas: ${lat}, ${lng}`;
    iframe.src = src;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeMapModal() {
    if (!modal || !iframe) return;
    iframe.src = '';
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  document.querySelectorAll('[data-branch-map]').forEach((button) => {
    button.addEventListener('click', () => {
      const city = button.getAttribute('data-branch-map') ?? '';
      const lat = button.getAttribute('data-lat') ?? '';
      const lng = button.getAttribute('data-lng') ?? '';
      if (!city || !lat || !lng) return;
      openMapModal(city, lat, lng);
    });
  });

  closeBtn?.addEventListener('click', closeMapModal);
  modal?.addEventListener('click', (event) => {
    if (event.target === modal) {
      closeMapModal();
    }
  });
</script>
